[user]
	email = codewithakrthikg@gmail.com
	name = CompileWithG
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	line-numbers = true
	syntax-theme = tokyonight_night
	side-by-side = false
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[http]
	version = HTTP/1.1
