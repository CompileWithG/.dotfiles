#!/usr/bin/env python3
"""Top-bar indicator for Quick Notes. Click -> menu -> Open (or middle-click opens directly)."""
import os, subprocess
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
from gi.repository import Gtk, AyatanaAppIndicator3 as AI

QN = os.path.expanduser("~/.local/bin/quicknotes")


def open_notes(*_):
    subprocess.Popen([QN])


ind = AI.Indicator.new("quicknotes-indicator", "accessories-text-editor-symbolic",
                       AI.IndicatorCategory.APPLICATION_STATUS)
ind.set_status(AI.IndicatorStatus.ACTIVE)
ind.set_title("Quick Notes")

menu = Gtk.Menu()
open_item = Gtk.MenuItem(label="📝  Open Quick Notes")
open_item.connect("activate", open_notes)
menu.append(open_item)
menu.append(Gtk.SeparatorMenuItem())
quit_item = Gtk.MenuItem(label="Quit indicator")
quit_item.connect("activate", lambda *_: Gtk.main_quit())
menu.append(quit_item)
menu.show_all()
ind.set_menu(menu)
ind.set_secondary_activate_target(open_item)  # middle-click opens directly

Gtk.main()
